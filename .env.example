# AgentSec encryption key. MUST be >= 32 chars. Process refuses to start otherwise.
# Generate with: openssl rand -hex 32
AGENTSEC_KEY=

# Local proxy port (default 7777)
AGENTSEC_PORT=7777

# Upstream LLM API base URL (default https://api.anthropic.com)
AGENTSEC_UPSTREAM_URL=https://api.anthropic.com

# Detection sensitivity: strict | balanced | permissive (default balanced)
AGENTSEC_SENSITIVITY=balanced

# Quarantine timeout in seconds (default 60, max 600)
AGENTSEC_QUARANTINE_TIMEOUT_SEC=60

# Optional override for project_id (default SHA-256(CWD) truncated to 16 hex)
AGENTSEC_PROJECT=

# Pro/Team only (opt-in cloud sync)
AGENTSEC_CLOUD_API_KEY=
AGENTSEC_WEBHOOK_URL=
AGENTSEC_WEBHOOK_FORMAT=generic
