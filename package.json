{
  "name": "agentsec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Transparent agent security proxy. No code changes. No LLM in detection. Local-first.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "agentsec": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:nollm": "tsx scripts/check-no-llm-calls.ts",
    "check:trace": "tsx scripts/check-traceability.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "undici": "^7.26.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
